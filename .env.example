# Vigil environment variables — copy to .env and fill in.
# The .env file is gitignored; .env.example is committed as a template.

# Optional: VirusTotal API key. When set, MALICIOUS scans also query
# the VT public API and show the community result alongside Vigil's verdict.
# Get a free key at https://www.virustotal.com/gui/join-us
# Free tier: 4 requests/minute, 500/day, 15.5k/month.
VIGIL_VT_API_KEY=your_key_here
